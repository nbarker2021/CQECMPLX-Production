{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cqe_eg8_hidden_guess_result_v1",
  "title": "CQE-E/G8 Hidden Gate Result",
  "type": "object",
  "required": ["protocol", "candidate_id", "sealed_result_id", "gate_guess", "reveal", "score"],
  "properties": {
    "protocol": {"const": "hidden_guess_result_v1"},
    "candidate_id": {"type": "string"},
    "sealed_result_id": {"type": "string"},
    "gate_guess": {
      "type": "object",
      "required": ["decision", "confidence", "reason"],
      "properties": {
        "decision": {"enum": ["accept", "reject", "amortize", "signal", "defer"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"}
      }
    },
    "reveal": {
      "type": "object",
      "required": ["result", "source"],
      "properties": {
        "result": {"type": "string"},
        "source": {"type": "string"}
      }
    },
    "score": {
      "type": "object",
      "required": ["outcome"],
      "properties": {
        "outcome": {"enum": ["hit", "near_miss", "false_positive", "false_negative", "leakage", "invalid_context", "unscored"]},
        "delta": {"type": "string"}
      }
    }
  }
}
